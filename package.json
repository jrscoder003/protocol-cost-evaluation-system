{
  "name": "protocol-evaluation-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "dev:server": "tsx backend/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "dev:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop.ps1",
    "dev:status": "powershell -ExecutionPolicy Bypass -File ./scripts/status.ps1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "element-plus": "^2.8.5",
    "express": "^4.21.1",
    "form-data": "^4.0.5",
    "html-pdf-node": "^1.0.8",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pinia": "^2.3.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.12",
    "@types/sqlite3": "^3.1.11",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10"
  }
}
